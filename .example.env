# ============================================================
# PPT Translate — Provider Configuration
# ============================================================
# Set PROVIDER to select which provider to use.
# Supported: siliconflow, openai, deepseek, openrouter, custom
# Then fill in the corresponding API key and optional overrides.

PROVIDER=siliconflow

# --- SiliconFlow (default) ---
SILICONFLOW_API_KEY=sk-xxx
# SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V3.2
# SILICONFLOW_RPM=1000
# SILICONFLOW_TPM=100000

# --- OpenAI ---
# OPENAI_API_KEY=sk-xxx
# OPENAI_MODEL=gpt-4o
# OPENAI_RPM=500
# OPENAI_TPM=300000

# --- DeepSeek ---
# DEEPSEEK_API_KEY=sk-xxx
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_RPM=60
# DEEPSEEK_TPM=100000

# --- OpenRouter ---
# OPENROUTER_API_KEY=sk-or-xxx
# OPENROUTER_MODEL=openai/gpt-4o
# OPENROUTER_RPM=100
# OPENROUTER_TPM=200000

# --- Custom provider ---
# CUSTOM_BASE_URL=https://your-api.example.com/v1
# CUSTOM_API_KEY=your-key
# CUSTOM_MODEL=your-model
# CUSTOM_RPM=60
# CUSTOM_TPM=100000

# --- Translation parameters (overrides per-provider defaults) ---
# TRANSLATE_BATCH_SIZE=20
# TRANSLATE_BATCH_MAX_CHARS=12000
# TRANSLATE_MAX_WORKERS=8