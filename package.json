{
  "name": "ppt-translate",
  "version": "0.2.0",
  "description": "PPTX translation tool — preserve layout and formatting while translating text",
  "type": "module",
  "main": "dist/main.js",
  "bin": {
    "ppt-translate": "dist/cli.js"
  },
  "scripts": {
    "build": "bun build src/cli.ts --outdir dist --target bun",
    "dev": "bun run src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.9.10",
    "commander": "^12.1.0",
    "fast-xml-parser": "^5.2.3",
    "jszip": "^3.10.1",
    "p-limit": "^6.2.0",
    "pptxgenjs": "^4.0.1"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  }
}